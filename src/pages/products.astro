---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Products" description="Browse our collection of clean, minimal Notion templates.">
  <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Products</h1>
  <p style="color: var(--color-text-light); margin-bottom: 2rem;">Simple templates that just work. No complicated setup needed.</p>

  <div class="product-grid">
    <div class="product-card">
      <h3>💰 Monthly Budget Tracker</h3>
      <p style="color: var(--color-text-light); margin: 0.5rem 0;">Track your income and expenses in one place. 9 expense categories, 5 income categories, and sample data included.</p>
      <p class="price">$5.50</p>
      <a href="https://yossyland.gumroad.com/l/notion-monthly-budget-tracker" target="_blank" class="cta-button" style="display: inline-block; background: var(--color-primary); color: white; padding: 0.5rem 1.2rem; border-radius: 8px; font-weight: 600; margin-top: 0.75rem; font-size: 0.9rem;">Get Template →</a>
    </div>

    <!-- More products will be added here -->
  </div>
</BaseLayout>
