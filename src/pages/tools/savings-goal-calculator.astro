</style>

<script>
  const goalInput = document.getElementById('goal-amount') as HTMLInputElement;
  const currentInput = document.getElementById('current-savings') as HTMLInputElement;
  const monthlyInput = document.getElementById('monthly-contribution') as HTMLInputElement;
  const resultsSection = document.getElementById('results-section')!;
  const alreadyDone = document.getElementById('already-done')!;

  function formatCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function formatMonth(date: Date): string {
    return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  }

  function calculate() {
    const goal = parseFloat(goalInput.value) || 0;
    const current = parseFloat(currentInput.value) || 0;
    const monthly = parseFloat(monthlyInput.value) || 0;

    if (goal <= 0) {
      resultsSection.style.display = 'none';
      alreadyDone.style.display = 'none';
      return;
    }

    if (current >= goal) {
      resultsSection.style.display = 'none';
      alreadyDone.style.display = 'block';
      return;
    }

    alreadyDone.style.display = 'none';

    if (monthly <= 0) {
      resultsSection.style.display = 'none';
      return;
    }

    resultsSection.style.display = 'block';

    const remaining = goal - current;
    const months = Math.ceil(remaining / monthly);
    const pct = Math.min((current / goal) * 100, 100);

    // Progress
    document.getElementById('progress-pct')!.textContent = pct.toFixed(1) + '%';
    (document.getElementById('progress-fill') as HTMLElement).style.width = pct + '%';
    document.getElementById('progress-current')!.textContent = formatCurrency(current) + ' saved';
    document.getElementById('progress-goal')!.textContent = formatCurrency(goal) + ' goal';

    // Stats
    document.getElementById('stat-months')!.textContent = months.toString();

    const targetDate = new Date();
    targetDate.setMonth(targetDate.getMonth() + months);
    document.getElementById('stat-date')!.textContent = formatMonth(targetDate);
    document.getElementById('stat-remaining')!.textContent = formatCurrency(remaining);

    // Timeline
    const timelineCard = document.getElementById('timeline-card')!;
    const timeline = document.getElementById('timeline')!;

    if (months <= 120) {
      timelineCard.style.display = 'block';
      timeline.innerHTML = '';

      const milestones: { pct: number; label: string }[] = [
        { pct: 0, label: 'Start' },
        { pct: 25, label: '25% milestone' },
        { pct: 50, label: 'Halfway there!' },
        { pct: 75, label: '75% milestone' },
        { pct: 100, label: 'Goal reached!' },
      ];

      milestones.forEach((ms, idx) => {
        const msAmount = goal * (ms.pct / 100);
        const msMonths = msAmount <= current ? 0 : Math.ceil((msAmount - current) / monthly);
        const msDate = new Date();
        msDate.setMonth(msDate.getMonth() + msMonths);

        const isDone = current >= msAmount;
        const isLast = idx === milestones.length - 1;

        let html = `<div class="tl-item">
          <div class="tl-dot-wrap">
            <div class="tl-dot ${isDone ? 'done' : (idx === 0 ? 'active' : '')}"></div>
            ${!isLast ? '<div class="tl-line"></div>' : ''}
          </div>
          <div class="tl-content">
            <div class="tl-date">${formatMonth(msDate)}</div>
            <div class="tl-amount">${formatCurrency(msAmount)}</div>
            <span class="tl-milestone">${ms.label}</span>
          </div>
        </div>`;
        timeline.innerHTML += html;
      });
    } else {
      timelineCard.style.display = 'none';
    }

    // Tip
    const tipCard = document.getElementById('tip-card')!;
    const tipText = document.getElementById('tip-text')!;
    tipCard.style.display = 'flex';

    if (months > 60) {
      tipText.innerHTML = `At this rate, it will take <strong>${Math.floor(months / 12)} years and ${months % 12} months</strong>. Consider increasing your monthly contribution — even an extra $100/month would save you ${Math.ceil(remaining / (monthly + 100))} months of waiting.`;
    } else if (months > 24) {
      const extraMonths = months - Math.ceil(remaining / (monthly * 1.2));
      tipText.innerHTML = `Great plan! Increasing your contribution by just 20% (to ${formatCurrency(monthly * 1.2)}/month) would get you there <strong>${extraMonths} months sooner</strong>.`;
    } else if (months <= 6) {
      tipText.innerHTML = `You are so close! Just <strong>${months} months</strong> to go. Stay consistent and you will be celebrating before you know it.`;
    } else {
      tipText.innerHTML = `Solid progress! At ${formatCurrency(monthly)}/month, you will reach your goal in <strong>${months} months</strong>. Automate your transfers so you never miss a contribution.`;
    }
  }

  [goalInput, currentInput, monthlyInput].forEach(el => {
    el.addEventListener('input', calculate);
  });
</script>
