    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    color: #fff;
  }
  .tool-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .tool-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .tool-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1rem;
  }
  .gradient-text {
    background: linear-gradient(90deg, #ffd6e0, #ffecd2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .tool-subtitle {
    font-size: 1.1rem;
    opacity: 0.92;
    line-height: 1.6;
    margin: 0;
  }

  .tool-app {
    padding: 2.5rem 1.5rem;
    background: #f8f9fb;
  }
  .tool-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .inputs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .input-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .input-card label {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: #1a1a2e;
