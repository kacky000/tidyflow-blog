    background: #fff;
    border-radius: 16px;
    padding: 3rem 2rem;
    text-align: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .done-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 0.75rem;
  }
  .done-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.4rem;
    color: #1a1a2e;
  }
  .done-card p {
    margin: 0;
    color: #666;
  }

  .tool-cta {
    padding: 2.5rem 1.5rem;
    background: #fff;
  }
  .cta-card {
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 20px;
    padding: 2.5rem;
    text-align: center;
    color: #fff;
  }
  .cta-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.5rem;
    font-weight: 800;
  }
  .cta-card p {
