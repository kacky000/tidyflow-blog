---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Free 50/30/20 Budget Calculator — Instantly Split Your Income';
const description = 'Enter your monthly after-tax income and instantly see how to split it using the 50/30/20 budgeting rule. Free, no signup, works in your browser.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "50/30/20 Budget Calculator",
      "url": "https://gettidyflow.com/tools/budget-calculator",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "description": description
    })} />
  </Fragment>

  <section class="tool-hero">
    <div class="tool-hero-inner">
      <span class="tool-badge">Free Tool — No Signup Required</span>
      <h1>50/30/20 <span class="gradient-text">Budget Calculator</span></h1>
      <p class="tool-subtitle">Enter your monthly after-tax income below and instantly see how to allocate your money using the popular 50/30/20 budgeting rule — the simplest way to take control of your finances.</p>
    </div>
  </section>

  <section class="tool-app">
    <div class="tool-container">
      <div class="calc-card">
        <label for="income-input" class="input-label">Monthly After-Tax Income</label>
        <div class="input-wrapper">
          <span class="currency-symbol">$</span>
          <input
            type="number"
            id="income-input"
            placeholder="e.g. 4,000"
            min="0"
            step="100"
            aria-label="Monthly after-tax income in dollars"
          />
        </div>
      </div>

      <div class="results-grid" id="results-grid" style="display:none;">
        <div class="result-card needs-card">
          <div class="result-header">
            <span class="result-icon">🏠</span>
            <div>
              <h3>Needs — 50%</h3>
              <p class="result-amount" id="needs-amount">$0</p>
            </div>
          </div>
          <div class="bar-container">
            <div class="bar bar-needs" id="bar-needs" style="width:0%"></div>
          </div>
          <p class="result-tip">Rent/mortgage, groceries, utilities, insurance, minimum debt payments, transportation. These are expenses you <strong>cannot</strong> skip.</p>
        </div>

        <div class="result-card wants-card">
          <div class="result-header">
            <span class="result-icon">🎉</span>
            <div>
              <h3>Wants — 30%</h3>
              <p class="result-amount" id="wants-amount">$0</p>
            </div>
          </div>
          <div class="bar-container">
            <div class="bar bar-wants" id="bar-wants" style="width:0%"></div>
          </div>
          <p class="result-tip">Dining out, streaming subscriptions, hobbies, vacations, shopping. Enjoyable but not essential — cut here first if money is tight.</p>
        </div>

        <div class="result-card savings-card">
          <div class="result-header">
            <span class="result-icon">💰</span>
            <div>
              <h3>Savings & Debt — 20%</h3>
              <p class="result-amount" id="savings-amount">$0</p>
            </div>
          </div>
          <div class="bar-container">
            <div class="bar bar-savings" id="bar-savings" style="width:0%"></div>
          </div>
          <p class="result-tip">Emergency fund, retirement contributions (401k/IRA), extra debt payments, investments. Pay yourself first — this is how wealth is built.</p>
        </div>
      </div>

      <div class="yearly-summary" id="yearly-summary" style="display:none;">
        <h3>Your Yearly Breakdown</h3>
        <div class="yearly-grid">
          <div class="yearly-item">
            <span class="yearly-label">Needs</span>
            <span class="yearly-value" id="yearly-needs">$0</span>
          </div>
          <div class="yearly-item">
            <span class="yearly-label">Wants</span>
            <span class="yearly-value" id="yearly-wants">$0</span>
          </div>
          <div class="yearly-item">
            <span class="yearly-label">Savings</span>
            <span class="yearly-value" id="yearly-savings">$0</span>
          </div>
          <div class="yearly-item yearly-total">
            <span class="yearly-label">Total Annual Income</span>
            <span class="yearly-value" id="yearly-total">$0</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="tool-cta">
    <div class="tool-container">
      <div class="cta-card">
        <h2>Track Your Budget Automatically</h2>
        <p>Knowing your 50/30/20 split is the first step. The next step is <strong>actually tracking</strong> where your money goes every month. Our Notion Budget Tracker makes it effortless.</p>
        <a href="https://gettidyflow.gumroad.com" target="_blank" rel="noopener" class="cta-button">Get the Notion Budget Tracker &rarr;</a>
      </div>
    </div>
  </section>

  <section class="tool-content">
    <div class="tool-container content-narrow">
      <h2>What Is the 50/30/20 Budget Rule?</h2>
      <p>The 50/30/20 rule is a simple budgeting framework popularized by Senator Elizabeth Warren in her book <em>All Your Worth</em>. It divides your after-tax income into three categories:</p>
      <ul>
        <li><strong>50% for Needs</strong> — essential living expenses you cannot avoid</li>
        <li><strong>30% for Wants</strong> — lifestyle spending that makes life enjoyable</li>
        <li><strong>20% for Savings & Debt Repayment</strong> — building your financial future</li>
      </ul>
      <p>This rule works because it is easy to remember and flexible enough for most income levels. You do not need to track every single purchase — just make sure each category stays within its target percentage.</p>

      <h2>How to Use This Calculator</h2>
      <ol>
        <li>Enter your <strong>monthly after-tax income</strong> (the amount that hits your bank account, not your gross salary).</li>
        <li>The calculator instantly shows how much to allocate to Needs, Wants, and Savings.</li>
        <li>Compare these numbers to your current spending to find areas for adjustment.</li>
      </ol>

      <h2>Tips for Making the 50/30/20 Rule Work</h2>
      <ul>
        <li><strong>Automate your savings</strong> — set up automatic transfers on payday so you never forget.</li>
        <li><strong>Review monthly</strong> — spending patterns shift; re-evaluate every 30 days.</li>
        <li><strong>Adjust the ratios</strong> — if you live in an expensive city, 60/20/20 might be more realistic. The key is having a system.</li>
        <li><strong>Track with a tool</strong> — a spreadsheet or <a href="/blog/how-to-track-expenses-in-notion/">Notion budget tracker</a> keeps you honest.</li>
      </ul>

      <h2>Related Resources</h2>
      <ul>
        <li><a href="/blog/50-30-20-budget-rule-notion/">How to Apply the 50/30/20 Rule in Notion</a></li>
        <li><a href="/blog/budgeting-mistakes-to-avoid/">Common Budgeting Mistakes to Avoid</a></li>
        <li><a href="/blog/monthly-budget-checklist/">Monthly Budget Checklist</a></li>
        <li><a href="/blog/best-notion-budget-templates-2026/">Best Notion Budget Templates in 2026</a></li>
      </ul>

      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>Should I use gross or net income?</summary>
        <p>Always use your <strong>net (after-tax) income</strong> — the amount deposited into your bank account. Using gross income will overestimate what you have available.</p>
      </details>
      <details>
        <summary>What if my needs exceed 50%?</summary>
        <p>This is common in high-cost-of-living areas. Consider a modified ratio like 60/20/20 or 70/15/15. The important thing is to have a plan and stick to it. Look for ways to reduce fixed costs — refinancing, downsizing, or switching providers.</p>
      </details>
      <details>
        <summary>Does the 50/30/20 rule work for low incomes?</summary>
        <p>The percentages may need adjusting, but the framework still helps. Even saving 5-10% is better than nothing. Focus on covering needs first, then gradually increase savings as your income grows.</p>
      </details>
      <details>
        <summary>Where does debt repayment go?</summary>
        <p>Minimum payments on debt (credit cards, student loans) count as <strong>Needs</strong>. Any extra payments above the minimum go into the <strong>Savings & Debt</strong> category.</p>
      </details>
      <details>
        <summary>Is this rule good for couples?</summary>
        <p>Yes. Combine both after-tax incomes and apply the rule to your household total. This gives you a shared budget framework while allowing flexibility within categories.</p>
      </details>
    </div>
  </section>
</BaseLayout>

<style>
  .tool-hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    color: #fff;
  }
  .tool-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .tool-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }
  .tool-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1rem;
  }
  .gradient-text {
    background: linear-gradient(90deg, #ffd6e0, #ffecd2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .tool-subtitle {
    font-size: 1.1rem;
    opacity: 0.92;
    line-height: 1.6;
    margin: 0;
  }

  .tool-app {
    padding: 2.5rem 1.5rem;
    background: #f8f9fb;
  }
  .tool-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .calc-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    margin-bottom: 2rem;
  }
  .input-label {
    display: block;
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
    color: #1a1a2e;
  }
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  .currency-symbol {
    position: absolute;
    left: 1.25rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: #667eea;
  }
  #income-input {
    width: 100%;
    padding: 1rem 1rem 1rem 2.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    transition: border-color 0.2s;
    outline: none;
    font-family: inherit;
    color: #1a1a2e;
  }
  #income-input:focus {
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
  }
  #income-input::placeholder {
    color: #a0aec0;
    font-weight: 400;
  }

  .results-grid {
    display: grid;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .result-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    border-left: 5px solid transparent;
  }
  .needs-card { border-left-color: #667eea; }
  .wants-card { border-left-color: #f093fb; }
  .savings-card { border-left-color: #43e97b; }

  .result-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .result-icon {
    font-size: 2rem;
    line-height: 1;
  }
  .result-header h3 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #555;
  }
  .result-amount {
    margin: 0.15rem 0 0;
    font-size: 1.75rem;
    font-weight: 800;
    color: #1a1a2e;
  }

  .bar-container {
    width: 100%;
    height: 10px;
    background: #f0f0f5;
    border-radius: 999px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .bar {
    height: 100%;
    border-radius: 999px;
    transition: width 0.5s ease;
  }
  .bar-needs { background: linear-gradient(90deg, #667eea, #764ba2); }
  .bar-wants { background: linear-gradient(90deg, #f093fb, #f5576c); }
  .bar-savings { background: linear-gradient(90deg, #43e97b, #38f9d7); }

  .result-tip {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  .yearly-summary {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .yearly-summary h3 {
    margin: 0 0 1rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a2e;
  }
  .yearly-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .yearly-item {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    background: #f8f9fb;
    border-radius: 10px;
  }
  .yearly-label {
    font-size: 0.9rem;
    color: #666;
  }
  .yearly-value {
    font-weight: 700;
    color: #1a1a2e;
  }
  .yearly-total {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff;
  }
  .yearly-total .yearly-label,
  .yearly-total .yearly-value {
    color: #fff;
  }

  .tool-cta {
    padding: 2.5rem 1.5rem;
    background: #fff;
  }
  .cta-card {
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 20px;
    padding: 2.5rem;
    text-align: center;
    color: #fff;
  }
  .cta-card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.5rem;
    font-weight: 800;
  }
  .cta-card p {
    margin: 0 0 1.5rem;
    opacity: 0.92;
    line-height: 1.6;
  }
  .cta-button {
    display: inline-block;
    background: #fff;
    color: #667eea;
    font-weight: 700;
    padding: 0.85rem 2rem;
    border-radius: 999px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  .tool-content {
    padding: 3rem 1.5rem 4rem;
    background: #f8f9fb;
  }
  .content-narrow {
    max-width: 720px;
    margin: 0 auto;
  }
  .tool-content h2 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #1a1a2e;
    margin: 2.5rem 0 0.75rem;
  }
  .tool-content h2:first-child {
    margin-top: 0;
  }
  .tool-content p,
  .tool-content li {
    font-size: 1.02rem;
    line-height: 1.7;
    color: #444;
  }
  .tool-content ul,
  .tool-content ol {
    padding-left: 1.25rem;
    margin: 0.5rem 0 1rem;
  }
  .tool-content li {
    margin-bottom: 0.35rem;
  }
  .tool-content a {
    color: #667eea;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .tool-content details {
    background: #fff;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }
  .tool-content summary {
    font-weight: 600;
    cursor: pointer;
    color: #1a1a2e;
    font-size: 1.02rem;
  }
  .tool-content details p {
    margin: 0.75rem 0 0;
  }

  @media (max-width: 640px) {
    .yearly-grid {
      grid-template-columns: 1fr;
    }
    .cta-card {
      padding: 2rem 1.5rem;
    }
  }
</style>

<script>
  const input = document.getElementById('income-input') as HTMLInputElement;
  const resultsGrid = document.getElementById('results-grid')!;
  const yearlySummary = document.getElementById('yearly-summary')!;

  function formatCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calculate() {
    const income = parseFloat(input.value) || 0;
    if (income <= 0) {
      resultsGrid.style.display = 'none';
      yearlySummary.style.display = 'none';
      return;
    }

    const needs = income * 0.5;
    const wants = income * 0.3;
    const savings = income * 0.2;

    resultsGrid.style.display = 'grid';
    yearlySummary.style.display = 'block';

    document.getElementById('needs-amount')!.textContent = formatCurrency(needs);
    document.getElementById('wants-amount')!.textContent = formatCurrency(wants);
    document.getElementById('savings-amount')!.textContent = formatCurrency(savings);

    (document.getElementById('bar-needs') as HTMLElement).style.width = '50%';
    (document.getElementById('bar-wants') as HTMLElement).style.width = '30%';
    (document.getElementById('bar-savings') as HTMLElement).style.width = '20%';

    document.getElementById('yearly-needs')!.textContent = formatCurrency(needs * 12);
    document.getElementById('yearly-wants')!.textContent = formatCurrency(wants * 12);
    document.getElementById('yearly-savings')!.textContent = formatCurrency(savings * 12);
    document.getElementById('yearly-total')!.textContent = formatCurrency(income * 12);
  }

  input.addEventListener('input', calculate);
</script>
