const MECHANICAL_TRANSITIONS = [
  { phrase: "furthermore", severity: "med" },
  { phrase: "moreover", severity: "med" },
  { phrase: "additionally", severity: "med" },
  { phrase: "consequently", severity: "med" },
  { phrase: "nevertheless", severity: "med" },
  { phrase: "on the other hand", severity: "med" },
  { phrase: "that being said", severity: "med" },
  { phrase: "with that in mind", severity: "med" },
  { phrase: "having established that", severity: "med" },
  { phrase: "it is worth mentioning", severity: "med" },
  { phrase: "moving forward", severity: "med" },
  { phrase: "in light of", severity: "med" },
];

const READER_ADDRESS = [
  { phrase: "you might be wondering", severity: "med" },
  { phrase: "you may be wondering", severity: "med" },
  { phrase: "as you can see", severity: "med" },
  { phrase: "as you may know", severity: "med" },
  { phrase: "as mentioned earlier", severity: "med" },
  { phrase: "as we discussed", severity: "med" },
  { phrase: "as previously mentioned", severity: "med" },
  { phrase: "imagine a world where", severity: "high" },
  { phrase: "picture this", severity: "low" },
  { phrase: "have you ever wondered", severity: "med" },
];

// === ANALYSIS ENGINE ===

function countWords(text) {
  return text.trim().split(/\s+/).filter(w => w.length > 0).length;
}

function getSentences(text) {
  return text.split(/[.!?]+/).map(s => s.trim()).filter(s => s.length > 5);
}

function getParagraphs(text) {
  return text.split(/\n\s*\n/).map(p => p.trim()).filter(p => p.length > 10);
}

function findPhraseMatches(text, phraseList) {
  const lower = text.toLowerCase();
  const matches = [];
  for (const item of phraseList) {
    const p = item.phrase.toLowerCase();
    let idx = lower.indexOf(p);
    while (idx !== -1) {
      const start = Math.max(0, idx - 30);
      const end = Math.min(text.length, idx + p.length + 30);
      const context = text.substring(start, end);
      matches.push({ ...item, index: idx, context });
      idx = lower.indexOf(p, idx + p.length);
    }
  }
  return matches;
}

function analyzeDeadPhrases(text) {
  const matches = findPhraseMatches(text, DEAD_PHRASES);
  const wordCount = countWords(text);
  const density = matches.length / (wordCount / 500);
  let score = Math.min(10, Math.round(density * 2.5));
  return { score, matches, count: matches.length };
}

function analyzeStructuralUniformity(text) {
  const paras = getParagraphs(text);
  const sentences = getSentences(text);
  let score = 0;
  const issues = [];

  // Check paragraph length uniformity
  if (paras.length >= 3) {
    const lengths = paras.map(p => countWords(p));
    const avg = lengths.reduce((a,b) => a+b, 0) / lengths.length;
    const variance = lengths.reduce((sum, l) => sum + Math.pow(l - avg, 2), 0) / lengths.length;
    const cv = Math.sqrt(variance) / avg; // coefficient of variation
    if (cv < 0.25) { score += 4; issues.push("Paragraphs are suspiciously similar in length (low variation)"); }
    else if (cv < 0.4) { score += 2; issues.push("Paragraphs could use more length variation"); }
  }

  // Check sentence length uniformity
  if (sentences.length >= 5) {
    const sLengths = sentences.map(s => s.split(/\s+/).length);
    const avg = sLengths.reduce((a,b) => a+b, 0) / sLengths.length;
    const variance = sLengths.reduce((sum, l) => sum + Math.pow(l - avg, 2), 0) / sLengths.length;
    const cv = Math.sqrt(variance) / avg;
    if (cv < 0.3) { score += 3; issues.push("Sentence lengths are too uniform — mix short and long sentences"); }
    else if (cv < 0.45) { score += 1; }

    // Check for short sentences (1-6 words) — humans use them, AI rarely does
    const shortSentences = sLengths.filter(l => l <= 6).length;
    const shortRatio = sentences.length > 0 ? shortSentences / sentences.length : 0;
    if (shortRatio < 0.05 && sentences.length > 6) {
      score += 2; issues.push("Almost no short punchy sentences — humans naturally mix in short sentences for emphasis");
    } else if (shortRatio < 0.1 && sentences.length > 8) {
      score += 1; issues.push("Few short sentences — try adding brief punchy lines for rhythm");
    }
  }

  // Check paragraph opening patterns
  if (paras.length >= 3) {
    const openings = paras.map(p => p.split(/\s+/).slice(0, 4).join(' ').toLowerCase());
    const uniqueRatio = new Set(openings).size / openings.length;
    if (uniqueRatio < 0.5) { score += 2; issues.push("Multiple paragraphs start the same way"); }
    else if (uniqueRatio < 0.7 && paras.length >= 5) { score += 1; issues.push("Several paragraphs have similar openings"); }
  }

  return { score: Math.min(10, score), issues };
}

function analyzeEmotionalFlatness(text) {
  const lower = text.toLowerCase();
  let score = 5; // Start neutral, adjust up/down
  const issues = [];

  // Check for opinion markers (reduce score if found)
  const opinionMarkers = ["i think", "i believe", "honestly", "in my experience", "personally", "i've found", "i noticed", "my take", "unpopular opinion", "hot take", "if you ask me", "i'd argue", "frankly", "to be honest", "i'm convinced"];
  const opinionCount = opinionMarkers.filter(m => lower.includes(m)).length;
  score -= Math.min(3, opinionCount);

  // Check for humor/informal markers
  const humorMarkers = ["lol", "haha", "spoiler:", "plot twist", "nope", "yep", "nah", "btw", "tbh", "imo", "fwiw", "no-brainer", "here's the thing", "let me be real", "look,", "ok so", "real talk"];
  const humorCount = humorMarkers.filter(m => lower.includes(m)).length;
  score -= Math.min(2, humorCount);

  // Check for hedging (increase score)
  const hedgingPhrases = ["it can be argued", "some might say", "on one hand", "some people prefer", "while others"];
  const hedgeCount = hedgingPhrases.filter(h => lower.includes(h)).length;
  if (hedgeCount >= 2) { score += 2; issues.push("Too much hedging — AI avoids taking strong positions"); }

  // Check for exclamation marks (humans use them occasionally)
  const exclamations = (text.match(/!/g) || []).length;
  const sentences = getSentences(text).length;
  if (sentences > 10 && exclamations === 0) { score += 1; issues.push("No exclamation marks — adding occasional emphasis makes text feel more human"); }

  // Check for parenthetical asides (humans love them)
  const parentheticals = (text.match(/\([^)]+\)/g) || []).length;
  if (parentheticals > 0) score -= 1;

  // Check for em-dash usage (human writing style)
  const emDashes = (text.match(/—|--/g) || []).length;
  if (emDashes > 0) score -= 1;

  // Check for contractions
  const contractions = (text.match(/(?:don't|won't|can't|isn't|aren't|wouldn't|couldn't|shouldn't|it's|that's|there's|here's|what's|who's|how's|I'm|I've|I'll|I'd|we're|we've|they're|they've|you're|you've|you'll|you'd|he's|she's|let's|didn't|doesn't|hasn't|haven't|wasn't|weren't)/gi) || []).length;
  if (contractions === 0 && countWords(text) > 150) {
    score += 2; issues.push("No contractions found — formal writing without contractions reads as AI-generated");
  } else if (contractions <= 1 && countWords(text) > 300) {
    score += 1; issues.push("Very few contractions — natural writing uses more contractions");
  }

  if (opinionCount === 0) issues.push("No personal opinions detected — the text feels impersonal");
  if (humorCount === 0 && countWords(text) > 300) issues.push("No humor or informal tone detected");

  return { score: Math.max(0, Math.min(10, score)), issues };
}

function analyzeSpecificity(text) {
  const lower = text.toLowerCase();
  let score = 5;
  const issues = [];

  // Vague quantifiers (increase score)
  const vagueQuants = ["many people", "a lot of", "some studies", "research shows", "experts say", "according to research", "studies suggest", "it has been shown", "data suggests", "evidence shows"];
  const vagueCount = vagueQuants.filter(v => lower.includes(v)).length;
  score += Math.min(3, vagueCount);
  if (vagueCount > 0) issues.push(`Found ${vagueCount} vague claims without specific sources`);

  // Check for specific numbers (decrease score)
  const specificNumbers = (text.match(/\d+(\.\d+)?%|\$\d+[\d,.]*|\d{1,3}(,\d{3})+/g) || []).length;
  score -= Math.min(3, Math.floor(specificNumbers / 2));
  if (specificNumbers === 0 && countWords(text) > 200) {
    issues.push("No specific numbers, percentages, or dollar amounts found");
  }

  // Check for proper nouns / brand names (rough check: capitalized words not at sentence start)
  const words = text.split(/\s+/);
  let properNouns = 0;
  for (let i = 1; i < words.length; i++) {
    if (/^[A-Z][a-z]+/.test(words[i]) && !/^[.!?]/.test(words[i-1].slice(-1))) {
      properNouns++;
    }
  }
  if (properNouns > 3) score -= 1;
  if (properNouns === 0 && countWords(text) > 300) {
    score += 1; issues.push("Few or no proper nouns (brand names, tools, places) — content feels generic");
  }

  // Check for "about/around" with round numbers
  const roundNumbers = (lower.match(/(?:about|around|roughly|approximately)\s+\d+0+/g) || []).length;
  if (roundNumbers >= 2) { score += 1; issues.push("Multiple round/approximate numbers — humans tend to use more specific figures"); }

  return { score: Math.max(0, Math.min(10, score)), issues };
}

function analyzeOverOrganization(text) {
  let score = 0;
  const issues = [];

  const paras = getParagraphs(text);

  // Check for bullet/list heavy content
  const bulletLines = (text.match(/^[\s]*[-•*]\s/gm) || []).length;
  const totalLines = text.split('\n').filter(l => l.trim()).length;
  const bulletRatio = totalLines > 0 ? bulletLines / totalLines : 0;
  if (bulletRatio > 0.4) { score += 3; issues.push("Over 40% of content is bullet points — mix in more prose paragraphs"); }
  else if (bulletRatio > 0.25) { score += 1; issues.push("High ratio of bullet points to prose"); }

  // Check for numbered lists
  const numberedLines = (text.match(/^[\s]*\d+[.)]\s/gm) || []).length;
  if (numberedLines > 8) { score += 2; issues.push("Heavy use of numbered lists — break some into natural prose"); }

  // Check for transition sentences between sections
  const transitionPatterns = ["now that we've", "now let's", "let's move on", "next, we'll", "in the next section", "moving on to", "turning our attention", "with that in mind", "having said that", "that said,", "as we can see", "as you can see"];
  const transCount = transitionPatterns.filter(t => text.toLowerCase().includes(t)).length;
  if (transCount >= 2) { score += 3; issues.push("Formulaic section transitions found — try more natural flow between sections"); }
  else if (transCount >= 1) { score += 1; }

  // Check heading symmetry (all H2 sections roughly equal)
  const h2Sections = text.split(/^#{2}\s/m).filter(s => s.trim());
  if (h2Sections.length >= 3) {
    const sectionLengths = h2Sections.map(s => countWords(s));
    const avg = sectionLengths.reduce((a,b) => a+b, 0) / sectionLengths.length;
    const maxDev = Math.max(...sectionLengths.map(l => Math.abs(l - avg)));
    if (maxDev < avg * 0.2) { score += 2; issues.push("All sections are suspiciously similar in length"); }
  }

  // Check for formulaic introduction + conclusion pattern (common in AI text)
  const lowerText = text.toLowerCase();
  const hasIntro = /^(in today|have you ever|when it comes|whether you|if you'?re|are you)/.test(lowerText.trim());
  const hasConclusion = /(in conclusion|to sum up|in summary|to summarize|in closing|as we'?ve seen|as you can see|the bottom line|by (leveraging|harnessing|embracing|utilizing))\b/.test(lowerText);
  if (hasIntro && hasConclusion) { score += 3; issues.push("Classic AI intro + conclusion pattern detected"); }
  else if (hasConclusion) { score += 2; issues.push("Formulaic conclusion pattern detected"); }
  else if (hasIntro) { score += 1; }

  return { score: Math.min(10, score), issues };
}

function analyzeMechanicalTransitions(text) {
  const matches = findPhraseMatches(text, MECHANICAL_TRANSITIONS);
  let score = 0;
  const issues = [];

  if (matches.length >= 5) { score = 8; issues.push("Heavy reliance on formal transition words"); }
  else if (matches.length >= 3) { score = 5; issues.push("Multiple mechanical transitions found"); }
  else if (matches.length >= 1) { score = 2; }

  // Check "First... Second... Third..." pattern
  const lower = text.toLowerCase();
  const ordinalRegex = /\b(first(?:ly|,| and foremost)|second(?:ly|,)|third(?:ly|,)|fourth(?:ly|,)|fifth(?:ly|,)|finally,|lastly,)\b/gi;
  const ordCount = (text.match(ordinalRegex) || []).length;
  if (ordCount >= 3) { score += 3; issues.push("Sequential ordinal pattern (First, Second, Third...) detected"); }
  else if (ordCount >= 2) { score += 1; issues.push("Ordinal transitions found"); }

  return { score: Math.min(10, score), matches, issues };
}

function analyzeReaderAddress(text) {
  const matches = findPhraseMatches(text, READER_ADDRESS);
  let score = 0;
  const issues = [];

  if (matches.length >= 3) { score = 7; issues.push("Excessive formulaic reader address"); }
  else if (matches.length >= 2) { score = 4; issues.push("Multiple formulaic reader address phrases found"); }
  else if (matches.length >= 1) { score = 2; }

  // Check "you" frequency (too much = AI trying to be conversational)
  const sentences = getSentences(text);
  const youSentences = sentences.filter(s => /\byou\b/i.test(s)).length;
  const youRatio = sentences.length > 0 ? youSentences / sentences.length : 0;
  if (youRatio > 0.5) { score += 3; issues.push("Over 50% of sentences address 'you' — feels over-directed"); }
  else if (youRatio > 0.35) { score += 1; issues.push("Frequent 'you' usage — moderate reader address"); }

  return { score: Math.min(10, score), matches, issues };
}

// === MAIN ANALYSIS ===
function analyzeText(text) {
  const deadPhrases = analyzeDeadPhrases(text);
  const structure = analyzeStructuralUniformity(text);
  const emotion = analyzeEmotionalFlatness(text);
  const specificity = analyzeSpecificity(text);
  const organization = analyzeOverOrganization(text);
  const transitions = analyzeMechanicalTransitions(text);
  const readerAddr = analyzeReaderAddress(text);

  const categories = [
    { name: "Dead Phrases", icon: "💀", ...deadPhrases },
    { name: "Structural Uniformity", icon: "📐", ...structure },
    { name: "Emotional Flatness", icon: "😐", ...emotion },
    { name: "Lack of Specificity", icon: "🌫️", ...specificity },
    { name: "Over-Organization", icon: "📋", ...organization },
    { name: "Mechanical Transitions", icon: "🔗", ...transitions },
    { name: "Unnatural Reader Address", icon: "🎤", ...readerAddr },
  ];

  const totalScore = categories.reduce((sum, c) => sum + c.score, 0);

  // Collect all issues
  const allIssues = [];
  for (const cat of categories) {
    if (cat.matches) {
      for (const m of cat.matches) {
        allIssues.push({
          category: cat.name,
          severity: m.severity || "med",
          text: m.context,
          phrase: m.phrase,
          fix: m.fix || `Rephrase to sound more natural`,
        });
      }
    }
    if (cat.issues) {
      for (const issue of cat.issues) {
        allIssues.push({ category: cat.name, severity: "med", text: issue, phrase: "", fix: "" });
      }
    }
  }

  // Sort by severity
  const severityOrder = { high: 0, med: 1, low: 2 };
  allIssues.sort((a, b) => severityOrder[a.severity] - severityOrder[b.severity]);

  return { totalScore, categories, issues: allIssues };
}

// === PROMPT GENERATOR ===
function generatePrompt(text, result) {
  const topCategories = result.categories
    .filter(c => c.score >= 4)
    .sort((a, b) => b.score - a.score)
    .slice(0, 3);

  const deadMatches = result.issues.filter(i => i.category === "Dead Phrases").slice(0, 5);

  let prompt = `You are a writing editor who specializes in making AI-generated content sound authentically human. Rewrite the following text to fix these specific issues:\n\n`;

  prompt += `ISSUES FOUND:\n`;
  for (const cat of topCategories) {
    prompt += `- ${cat.name} (severity: ${cat.score}/10)\n`;
  }

  if (deadMatches.length > 0) {
    prompt += `\nDEAD PHRASES TO REPLACE:\n`;
    for (const m of deadMatches) {
      prompt += `- "${m.phrase}" → ${m.fix}\n`;
    }
  }

  prompt += `\nREWRITE RULES:\n`;
  prompt += `1. Vary sentence length dramatically (5-word sentences mixed with 25-word ones)\n`;
  prompt += `2. Replace ALL dead phrases with natural alternatives\n`;
  prompt += `3. Add at least one personal opinion or genuine reaction\n`;
  prompt += `4. Use contractions everywhere natural (don't, won't, isn't)\n`;
  prompt += `5. Start some sentences with And, But, or So\n`;
  prompt += `6. Keep the same meaning, keywords, and structure\n`;
  prompt += `7. Make it sound like a knowledgeable human wrote it, not an AI\n`;
  prompt += `\nTEXT TO REWRITE:\n`;
  prompt += text.substring(0, 3000);

  if (text.length > 3000) {
    prompt += `\n[Text truncated at 3000 characters for prompt length. Apply the same fixes to the rest.]`;
  }

  return prompt;
}

// === UI RENDERING ===
function renderResults(result) {
  const panel = document.getElementById('results-panel');
  const bottomCta = document.getElementById('bottom-cta');
  panel.style.display = 'block';
  bottomCta.style.display = 'block';

  // Animate score ring — Human Score (100 = fully human, 0 = fully AI)
  const total = result.totalScore; // 0-70, higher = more AI
  const humanScore = Math.round((1 - total / 70) * 100); // 0-100, higher = more human
  const circle = document.getElementById('score-circle');
  const circumference = 2 * Math.PI * 52;
  const offset = circumference - (humanScore / 100) * circumference;
  circle.style.strokeDashoffset = offset;

  // Color based on human score (higher = better)
  let ringColor, label, desc, badgeClass, badgeLabel;
  if (humanScore >= 80) {
    ringColor = 'var(--color-success, #10b981)'; label = 'Very Human!'; desc = 'Your text reads naturally with minimal AI patterns. Great job — it should pass most detectors.'; badgeClass = 'badge-green'; badgeLabel = 'Human-Like';
  } else if (humanScore >= 50) {
    ringColor = 'var(--color-warning, #f59e0b)'; label = 'Needs Some Work'; desc = 'Your text has noticeable AI patterns. Focus on the flagged categories below to improve.'; badgeClass = 'badge-yellow'; badgeLabel = 'Mixed';
  } else {
    ringColor = '#dc2626'; label = 'Heavily AI-Patterned'; desc = 'Your text shows strong AI patterns across multiple categories. Use the rewrite prompt below.'; badgeClass = 'badge-red'; badgeLabel = 'AI-Like';
  }
  circle.style.stroke = ringColor;
  document.getElementById('score-number').textContent = humanScore;
  document.getElementById('score-label').textContent = label;
  document.getElementById('score-description').textContent = desc;
  document.getElementById('score-badges').innerHTML = `<span class="score-badge ${badgeClass}">${badgeLabel}</span>`;

  // Categories
  const catEl = document.getElementById('categories');
  catEl.innerHTML = '';
  for (const cat of result.categories) {
    const catHuman = 10 - cat.score; // invert: 10 = fully human, 0 = fully AI
    const color = catHuman >= 7 ? 'var(--color-success, #10b981)' : catHuman >= 4 ? 'var(--color-warning, #f59e0b)' : '#dc2626';
    const row = document.createElement('div');
    row.className = 'category-row';
    row.innerHTML = `
      <span class="cat-name">${cat.icon} ${cat.name}</span>
      <div class="cat-bar-track"><div class="cat-bar-fill" style="width:${catHuman * 10}%;background:${color}"></div></div>
      <span class="cat-score" style="color:${color}">${catHuman}/10</span>
    `;
    catEl.appendChild(row);
  }

  // Issues
  const issuesList = document.getElementById('issues-list');
  const issueCount = document.getElementById('issue-count');
  issuesList.innerHTML = '';
  const displayIssues = result.issues.slice(0, 15);
  issueCount.textContent = `${result.issues.length} found`;

  for (const issue of displayIssues) {
    const item = document.createElement('div');
    item.className = `issue-item severity-${issue.severity}`;
    let html = `<div class="issue-category">${issue.category}</div>`;
    if (issue.phrase) {
      const highlighted = issue.text.replace(
        new RegExp(issue.phrase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi'),
        match => `<mark>${match}</mark>`
      );
      html += `<div class="issue-text">"...${highlighted}..."</div>`;
      if (issue.fix) html += `<div class="issue-fix">Fix: ${issue.fix}</div>`;
    } else {
      html += `<div class="issue-text">${issue.text}</div>`;
    }
    item.innerHTML = html;
    issuesList.appendChild(item);
  }
}

// === EVENT HANDLERS ===
const textarea = document.getElementById('text-input');
const analyzeBtn = document.getElementById('analyze-btn');
const clearBtn = document.getElementById('clear-btn');
const sampleBtn = document.getElementById('sample-btn');
const charCount = document.getElementById('char-count');
const copyPromptBtn = document.getElementById('copy-prompt-btn');

textarea.addEventListener('input', () => {
  const words = countWords(textarea.value);
  charCount.textContent = `${words} word${words !== 1 ? 's' : ''}`;
  analyzeBtn.disabled = words < 30;
});

analyzeBtn.addEventListener('click', () => {
  const text = textarea.value.trim();
  if (countWords(text) < 30) return;

  analyzeBtn.disabled = true;
  analyzeBtn.innerHTML = '<svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.49-8.49l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M7.76 7.76L4.93 4.93"/></svg> Analyzing...';

  // Small delay for UI feedback
  setTimeout(() => {
    const result = analyzeText(text);
    renderResults(result);

    // Generate prompt
    const prompt = generatePrompt(text, result);
    document.getElementById('prompt-box').textContent = prompt;

    analyzeBtn.disabled = false;
    analyzeBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg> Re-Analyze';
    clearBtn.style.display = 'inline-flex';

    // Smooth scroll to results
    document.getElementById('results-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 300);
});

clearBtn.addEventListener('click', () => {
  textarea.value = '';
  charCount.textContent = '0 words';
  analyzeBtn.disabled = true;
  analyzeBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg> Analyze Text';
  document.getElementById('results-panel').style.display = 'none';
  document.getElementById('bottom-cta').style.display = 'none';
  document.getElementById('error-banner').style.display = 'none';
  clearBtn.style.display = 'none';
  sampleBtn.style.display = 'inline-flex';
  textarea.focus();
});

