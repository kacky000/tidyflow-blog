  { phrase: "in the realm of", severity: "med", fix: "in / with / for" },
  { phrase: "embark on", severity: "med", fix: "start / begin" },
  { phrase: "embarking on", severity: "med", fix: "starting / beginning" },
  { phrase: "foster", severity: "med", fix: "build / encourage / grow" },
  { phrase: "fostering", severity: "med", fix: "building / encouraging / growing" },
  { phrase: "paramount", severity: "med", fix: "critical / key / essential" },
  { phrase: "plethora", severity: "med", fix: "many / lots of" },
  { phrase: "myriad", severity: "med", fix: "many / tons of" },
