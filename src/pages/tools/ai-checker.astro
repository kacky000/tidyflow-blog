---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Free AI Content Checker — Is Your Writing Too AI?';
const description = 'Paste your text and instantly see what makes it sound AI-generated. Get a score across 7 detection categories plus custom rewrite prompts. 100% free, no signup.';
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "AI Writing Coach",
      "url": "https://gettidyflow.com/tools/ai-checker",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "description": description
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="checker-hero">
    <div class="checker-hero-inner">
      <span class="checker-badge">Free Tool — No Signup Required</span>
      <h1>Is Your Writing <span class="gradient-text">Too AI?</span></h1>
      <p class="checker-subtitle">Paste your text below. We'll scan it across 7 detection categories, highlight the problems, and give you a custom rewrite prompt — all in your browser, no data sent anywhere.</p>
    </div>
  </section>

  <!-- Main App -->
  <section class="checker-app">
    <div class="checker-container">
      <div class="checker-grid">
        <!-- Left: Input & Results -->
        <div class="checker-main">
          <div class="input-area">
            <div class="input-header">
              <label for="text-input">Paste your text</label>
              <span class="char-count" id="char-count">0 words</span>
            </div>
            <textarea id="text-input" placeholder="Paste your blog post, article, or any text here to check for AI patterns..." rows="12"></textarea>
            <div class="input-actions">
              <button id="analyze-btn" class="btn-primary" disabled>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                Analyze Text
              </button>
              <button id="clear-btn" class="btn-ghost" style="display:none">Clear</button>
              <button id="sample-btn" class="btn-ghost">Try Sample Text</button>
            </div>
          </div>

          <!-- Error Banner -->
          <div id="error-banner" class="error-banner" style="display:none" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span id="error-message"></span>
          </div>

          <!-- Results (hidden until analysis) -->
          <div id="results-panel" class="results-panel" style="display:none" aria-live="polite" aria-label="Analysis results">
            <!-- Overall Score -->
            <div class="score-overview">
              <div class="score-ring-container">
                <svg class="score-ring" viewBox="0 0 120 120">
                  <circle cx="60" cy="60" r="52" fill="none" stroke="var(--color-border)" stroke-width="8"/>
                  <circle id="score-circle" cx="60" cy="60" r="52" fill="none" stroke="var(--color-primary)" stroke-width="8" stroke-linecap="round" stroke-dasharray="327" stroke-dashoffset="327" transform="rotate(-90 60 60)"/>
                </svg>
                <div class="score-value">
                  <span id="score-number">0</span>
                  <span class="score-max">/100</span>
                </div>
              </div>
              <div class="score-info">
                <h2 id="score-label">Analyzing...</h2>
                <p id="score-description"></p>
                <div class="score-badges" id="score-badges"></div>
              </div>
            </div>

            <!-- Category Breakdown -->
            <div class="category-breakdown">
              <h3>Human Score Breakdown</h3>
              <div class="categories" id="categories"></div>
            </div>

            <!-- Highlighted Issues -->
            <div class="issues-section">
              <h3>Flagged Issues <span class="issue-count" id="issue-count"></span></h3>
              <div class="issues-list" id="issues-list"></div>
            </div>

            <!-- Rewrite Prompt -->
            <div class="prompt-section">
              <h3>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Your Custom Rewrite Prompt
              </h3>
              <p class="prompt-desc">Copy this prompt into ChatGPT, Claude, or any AI tool to humanize your text:</p>
              <div class="prompt-box" id="prompt-box"></div>
              <button class="btn-copy" id="copy-prompt-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Copy Prompt
              </button>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="checker-sidebar">
          <div class="sidebar-card sidebar-cta">
            <div class="sidebar-cta-badge">150 Prompts</div>
            <h4>AI Prompt Pack for Content Creators V2.0</h4>
            <p>30 AI Humanization prompts + 120 content creation prompts. Excel + PDF, copy-paste ready.</p>
            <a href="https://gettidyflow.gumroad.com/l/mjrtjt" class="btn-primary btn-sm" target="_blank" rel="noopener">Get the Prompt Pack — $5.99</a>
          </div>

          <div class="sidebar-card">
            <h4>How It Works</h4>
            <div class="how-steps">
              <div class="how-step"><span class="step-num">1</span><span>Paste your text above</span></div>
              <div class="how-step"><span class="step-num">2</span><span>We scan for 7 AI patterns</span></div>
              <div class="how-step"><span class="step-num">3</span><span>See scores & flagged issues</span></div>
              <div class="how-step"><span class="step-num">4</span><span>Copy a custom rewrite prompt</span></div>
            </div>
          </div>

          <div class="sidebar-card">
            <h4>The 7 AI Patterns</h4>
            <ul class="pattern-list">
              <li><span class="pattern-icon">💀</span> Dead Phrases</li>
              <li><span class="pattern-icon">📐</span> Structural Uniformity</li>
              <li><span class="pattern-icon">😐</span> Emotional Flatness</li>
              <li><span class="pattern-icon">🌫️</span> Lack of Specificity</li>
              <li><span class="pattern-icon">📋</span> Over-Organization</li>
              <li><span class="pattern-icon">🔗</span> Mechanical Transitions</li>
              <li><span class="pattern-icon">🎤</span> Unnatural Reader Address</li>
            </ul>
          </div>

          <div class="sidebar-card">
            <h4>Privacy First</h4>
            <p class="privacy-note">Your text never leaves your browser. All analysis runs locally in JavaScript. No data is sent to any server.</p>
          </div>
        </aside>
      </div>

      <!-- Bottom CTA -->
      <div class="bottom-cta" id="bottom-cta" style="display:none">
        <div class="bottom-cta-inner">
          <div>
            <h3>Want 30 more humanization prompts?</h3>
            <p>The AI Prompt Pack V2.0 includes 30 AI Humanization prompts, from full-text rewrites to voice cloning — plus 120 content creation prompts.</p>
          </div>
          <a href="https://gettidyflow.gumroad.com/l/mjrtjt" class="btn-primary" target="_blank" rel="noopener">Get the Prompt Pack — $5.99</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ for SEO -->
  <section class="checker-faq">
    <div class="faq-inner">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>How does the AI content checker work?</h3>
          <p>Our tool scans your text for 7 categories of patterns that AI detection tools like GPTZero and Originality.ai flag. These include dead phrases, structural uniformity, emotional flatness, and more. It runs entirely in your browser — no data is ever sent to a server.</p>
        </div>
        <div class="faq-item">
          <h3>Is this tool free?</h3>
          <p>Yes, 100% free with no signup required. Paste your text, get instant results. We also offer an AI Prompt Pack with 30 advanced humanization prompts if you want to go deeper.</p>
        </div>
        <div class="faq-item">
          <h3>Will this help my content pass AI detectors?</h3>
          <p>This tool identifies the specific patterns that AI detectors flag. By fixing these issues — either manually or using the generated rewrite prompt — your content will read more naturally and score lower on AI detection tools.</p>
        </div>
        <div class="faq-item">
          <h3>What are "dead phrases" in AI writing?</h3>
          <p>Dead phrases are overused expressions that AI models tend to rely on, like "delve into," "it's important to note," "in today's fast-paced world," and "navigate the landscape." These phrases immediately signal AI-generated content to both readers and detection tools.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* ============ CHECKER HERO ============ */
.checker-hero {
  background: var(--gradient-hero);
  padding: var(--space-3xl) var(--space-xl) var(--space-2xl);
  text-align: center;
}
.checker-hero-inner {
  max-width: 720px;
  margin: 0 auto;
}
.checker-badge {
  display: inline-block;
  padding: 6px 16px;
  background: var(--color-primary-subtle);
  color: var(--color-primary);
  font-size: 0.8rem;
  font-weight: 600;
  border-radius: var(--radius-full);
  margin-bottom: var(--space-lg);
  letter-spacing: 0.02em;
}
.checker-hero h1 {
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 800;
  color: var(--color-text);
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin: 0 0 var(--space-lg);
}
.gradient-text {
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.checker-subtitle {
  font-size: 1.1rem;
  color: var(--color-text-secondary);
  line-height: 1.7;
  max-width: 600px;
  margin: 0 auto;
}

/* ============ MAIN LAYOUT ============ */
.checker-app {
  padding: 0 var(--space-xl) var(--space-3xl);
}
.checker-container {
  max-width: var(--max-width-wide);
  margin: 0 auto;
}
.checker-grid {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: var(--space-2xl);
  align-items: start;
}

/* ============ INPUT AREA ============ */
.input-area {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  box-shadow: var(--shadow-card);
}
.input-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}
.input-header label {
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--color-text);
}
.char-count {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  font-variant-numeric: tabular-nums;
}
textarea {
  width: 100%;
  min-height: 260px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  font-family: var(--font-sans);
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--color-text);
  background: var(--color-bg-alt);
  resize: vertical;
  transition: border-color var(--transition-fast);
}
textarea:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
}
textarea::placeholder {
  color: var(--color-text-muted);
}
.input-actions {
  display: flex;
  gap: var(--space-sm);
  margin-top: var(--space-md);
  flex-wrap: wrap;
}

/* ============ BUTTONS ============ */
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: var(--gradient-primary);
  color: white;
  border: none;
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-base);
  text-decoration: none;
}
.btn-primary:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: var(--shadow-md); }
.btn-primary:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.btn-primary:disabled:focus-visible { outline: 2px dotted var(--color-text-muted); }
.btn-primary.btn-sm { padding: 10px 18px; font-size: 0.85rem; width: 100%; justify-content: center; }
.btn-ghost {
  padding: 12px 20px;
  background: transparent;
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-fast);
}
.btn-ghost:hover { background: var(--color-bg-alt); border-color: var(--color-primary-light); color: var(--color-primary); }
.btn-ghost:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.btn-copy {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 20px;
  background: var(--color-primary-subtle);
  color: var(--color-primary);
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
}
.btn-copy:hover { background: var(--color-primary); color: white; }
.btn-copy:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.btn-copy:active { transform: scale(0.98); }
.btn-copy.copied { background: var(--color-success); color: white; border-color: transparent; }

/* ============ ERROR BANNER ============ */
.error-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: var(--space-md);
  background: rgba(239, 68, 68, 0.08);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: var(--radius-md);
  color: #dc2626;
  font-size: 0.88rem;
  margin-top: var(--space-md);
}

/* ============ SPIN ANIMATION ============ */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.spin { animation: spin 1s linear infinite; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ============ RESULTS ============ */
.results-panel { margin-top: var(--space-xl); animation: fadeUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards; }

.score-overview {
  display: flex;
  gap: var(--space-xl);
  align-items: center;
  padding: var(--space-xl);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.score-ring-container { position: relative; width: 120px; height: 120px; flex-shrink: 0; }
.score-ring { width: 100%; height: 100%; }
.score-value {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}
.score-value span:first-child { font-size: 2rem; font-weight: 800; color: var(--color-text); letter-spacing: -0.03em; }
.score-max { font-size: 0.85rem; color: var(--color-text-muted); }
.score-info h2 { font-size: 1.3rem; margin: 0 0 4px; color: var(--color-text); }
.score-info p { font-size: 0.9rem; color: var(--color-text-secondary); margin: 0 0 var(--space-sm); line-height: 1.5; }
.score-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.score-badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-size: 0.75rem;
  font-weight: 600;
}
.badge-green { background: rgba(16, 185, 129, 0.12); color: var(--color-success); }
.badge-yellow { background: rgba(245, 158, 11, 0.12); color: var(--color-warning); }
.badge-red { background: rgba(239, 68, 68, 0.12); color: #dc2626; }

/* Category Breakdown */
.category-breakdown {
  margin-top: var(--space-xl);
  padding: var(--space-xl);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.category-breakdown h3 { font-size: 1.1rem; margin: 0 0 var(--space-lg); }
.categories { display: flex; flex-direction: column; gap: var(--space-md); }
.category-row {
  display: grid;
  grid-template-columns: 180px 1fr 50px;
  gap: var(--space-md);
  align-items: center;
}
.cat-name {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--color-text);
  display: flex;
  align-items: center;
  gap: 6px;
}
.cat-bar-track {
  height: 8px;
  background: var(--color-surface);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.cat-bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.cat-score { font-size: 0.85rem; font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }

/* Issues */
.issues-section {
  margin-top: var(--space-xl);
  padding: var(--space-xl);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.issues-section h3 { font-size: 1.1rem; margin: 0 0 var(--space-lg); display: flex; align-items: center; gap: 8px; }
.issue-count {
  font-size: 0.75rem;
  background: var(--color-surface);
  color: var(--color-text-secondary);
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-weight: 600;
}
.issues-list { display: flex; flex-direction: column; gap: var(--space-sm); }
.issue-item {
  padding: var(--space-md);
  background: var(--color-bg-alt);
  border-radius: var(--radius-md);
  border-left: 3px solid var(--color-warning);
  font-size: 0.88rem;
  line-height: 1.6;
}
.issue-item.severity-high { border-left-color: #ef4444; }
.issue-item.severity-med { border-left-color: var(--color-warning); }
.issue-item.severity-low { border-left-color: var(--color-accent); }
.issue-category {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-muted);
  margin-bottom: 4px;
}
.issue-text { color: var(--color-text); }
.issue-text mark {
  background: rgba(245, 158, 11, 0.15);
  color: var(--color-text);
  padding: 1px 4px;
  border-radius: 3px;
  font-weight: 500;
}
.issue-fix { color: var(--color-text-secondary); font-style: italic; margin-top: 4px; }

/* Prompt Section */
.prompt-section {
  margin-top: var(--space-xl);
  padding: var(--space-xl);
  background: var(--color-bg);
  border: 1px solid var(--color-primary-light);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.prompt-section h3 {
  font-size: 1.1rem;
  margin: 0 0 var(--space-sm);
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--color-primary);
}
.prompt-desc { font-size: 0.85rem; color: var(--color-text-secondary); margin: 0 0 var(--space-md); }
.prompt-box {
  background: var(--color-bg-alt);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  font-family: var(--font-mono);
  font-size: 0.82rem;
  line-height: 1.7;
  color: var(--color-text);
  white-space: pre-wrap;
  max-height: 300px;
  overflow-y: auto;
  margin-bottom: var(--space-md);
}

/* ============ SIDEBAR ============ */
.checker-sidebar { position: sticky; top: 80px; display: flex; flex-direction: column; gap: var(--space-lg); }
.sidebar-card {
  padding: var(--space-lg);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.sidebar-card h4 { font-size: 1rem; margin: 0 0 var(--space-md); color: var(--color-text); }
.sidebar-card p { font-size: 0.88rem; color: var(--color-text-secondary); line-height: 1.6; margin: 0 0 var(--space-md); }
.sidebar-cta {
  background: linear-gradient(135deg, #eef2ff 0%, #e0f2fe 100%);
  border-color: var(--color-primary-light);
}
.sidebar-cta-badge {
  display: inline-block;
  padding: 3px 10px;
  background: var(--color-primary);
  color: white;
  font-size: 0.7rem;
  font-weight: 700;
  border-radius: var(--radius-full);
  margin-bottom: var(--space-sm);
  letter-spacing: 0.03em;
}
.how-steps { display: flex; flex-direction: column; gap: 12px; }
.how-step { display: flex; align-items: center; gap: 12px; font-size: 0.88rem; color: var(--color-text-secondary); }
.step-num {
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-primary-subtle);
  color: var(--color-primary);
  border-radius: var(--radius-full);
  font-weight: 700;
  font-size: 0.8rem;
  flex-shrink: 0;
}
.pattern-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pattern-list li {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  color: var(--color-text-secondary);
}
.pattern-icon { font-size: 1rem; }
.privacy-note { font-size: 0.82rem !important; color: var(--color-text-muted) !important; }

/* ============ BOTTOM CTA ============ */
.bottom-cta {
  margin-top: var(--space-2xl);
  padding: var(--space-2xl);
  background: linear-gradient(135deg, #eef2ff 0%, #e0f2fe 50%, #f0fdf4 100%);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-primary-light);
}
.bottom-cta-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-xl);
}
.bottom-cta h3 { font-size: 1.2rem; margin: 0 0 6px; }
