---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Productivity tips, Notion guides, and budgeting advice to help you get organized and stay on track.">

  <div class="page-header">
    <h1>Blog</h1>
    <p>Practical guides on budgeting, productivity, and making the most of Notion.</p>
  </div>

  <section class="section">
    <div class="container">
      <div class="post-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card post-card--has-thumb" style="text-decoration: none; color: inherit;">
            {post.data.heroImage && (
              <div class="post-card__thumb">
                <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="post-card__body">
              <div class="post-meta">
                <span class="post-date">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </span>
              </div>
              <h2>{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
              <span class="read-more">Read more</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
